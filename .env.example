# YouTube Data API v3 key
YOUTUBE_API_KEY=your_api_key_here

# Optional (Streamlit)
DEFAULT_MAX_RESULTS=20
MAX_ALLOWED_RESULTS=200

# Optional (daily crawl)
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxx
SPREADSHEET_ID=your_spreadsheet_id
SPREADSHEET_WORKSHEET_NAME=索引
TITLE_LIST_WORKSHEET_NAME=タイトルリスト
DAILY_MAX_RESULTS=50
# JSON string of Google Service Account credentials
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

DAILY_NEW_VIDEO_LIMIT=2
DAILY_RECHECK_LIMIT=5
DAILY_RECENT_RECHECK_HOURS=72
TIMESTAMP_COMMENT_THREAD_LIMIT=300
